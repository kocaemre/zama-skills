# ---------------------------------------------------------------------------
# Confidential Demo Token — frontend env vars
# ---------------------------------------------------------------------------
# Copy to `.env.local` for local dev. The same variables are documented here
# so Plan 05's README can point Vercel users at this file when configuring
# project env vars in the dashboard.
#
# All vars are NEXT_PUBLIC_* — they are inlined into the client bundle.
# Do NOT put secrets here.
# ---------------------------------------------------------------------------

# Sepolia JSON-RPC endpoint (Alchemy, Infura, or any public RPC).
# Example: https://eth-sepolia.g.alchemy.com/v2/<KEY>
NEXT_PUBLIC_SEPOLIA_RPC=

# WalletConnect Cloud project ID — required by RainbowKit's WalletConnect
# connector. Get one at https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Deployed Token contract address on Sepolia — populated by Plan 04 deploy.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Zama relayer URL (Sepolia testnet). The skill's runtime layer should
# verify this against https://docs.zama.org/protocol/protocol-apps/addresses/testnet/sepolia
# at boot since Zama updates these periodically.
NEXT_PUBLIC_RELAYER_URL=https://relayer.testnet.zama.cloud
