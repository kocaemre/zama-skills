# ----------------------------------------------------------------------
# Public env vars (committed). Secrets live in .env.deploy.local (gitignored).
# ----------------------------------------------------------------------

# Sepolia RPC endpoint (any provider works). Public RPCs:
#   https://ethereum-sepolia.publicnode.com
#   https://1rpc.io/sepolia
#   https://sepolia.gateway.tenderly.co
# Alchemy: https://www.alchemy.com   Infura: https://www.infura.io
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
INFURA_API_KEY=

# Etherscan API key for `pnpm hardhat verify`.
# https://etherscan.io/myapikey
# Optional — deploy script skips verify gracefully if missing.
ETHERSCAN_API_KEY=

# Zama relayer URL for the FRONTEND. Verify against
# https://docs.zama.org/protocol/protocol-apps/addresses/testnet/sepolia
# at boot since Zama updates these periodically.
RELAYER_URL=https://relayer.testnet.zama.cloud

# ----------------------------------------------------------------------
# Deploy credentials — DO NOT put values here.
# Create `.env.deploy.local` (gitignored) with one of:
#   DEPLOYER_PRIVATE_KEY=0x...        # preferred
#   DEPLOYER_MNEMONIC="word word ..." # fallback
# ----------------------------------------------------------------------
