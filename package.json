{
  "name": "zama-skills",
  "version": "0.0.0-dev",
  "description": "AI agent skills for building confidential dApps with the Zama Protocol (fhEVM) — Claude Code plugin + npx fallback",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Emre Koca",
    "email": "emrekoca2003@gmail.com"
  },
  "homepage": "https://github.com/<owner>/zama-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/<owner>/zama-skills.git"
  },
  "keywords": [
    "zama",
    "fhevm",
    "fhe",
    "confidential",
    "ethereum",
    "solidity",
    "claude-code",
    "ai-skills"
  ],
  "bin": {
    "zama-skills": "./bin/zama-skills.mjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "plugins",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "sync": "tsx scripts/build.ts",
    "sync:check": "tsx scripts/build.ts --check",
    "generic": "node scripts/generate-generic-docs.mjs",
    "generic:check": "node scripts/generate-generic-docs.mjs && git diff --exit-code generic/",
    "test": "vitest run --passWithNoTests",
    "test:smoke": "ZAMA_INIT_SMOKE=1 vitest run tests/integration --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.30",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "zod": "^3.25.0"
  }
}
